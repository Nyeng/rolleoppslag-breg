# Maskinporten / Brreg konfigurasjon
# Kopier denne fila til .env og fyll inn ekte verdier.

# Klient-ID fra Maskinporten (Samarbeidsportalen / selvbetjening)
MASKINPORTEN_CLIENT_ID=

# Hele JWK-en (privat nøkkel) som JSON på ÉN linje, omsluttet av enkle '...'
# Eksempel: MASKINPORTEN_JWK='{"alg":"RS256","kty":"RSA","kid":"...","d":"...","n":"...", ...}'
MASKINPORTEN_JWK=

# Standardverdier under peker mot test/PPE-miljøet. Endre kun ved behov.
# MASKINPORTEN_TOKEN_ENDPOINT=https://test.maskinporten.no/token
# MASKINPORTEN_AUDIENCE=https://test.maskinporten.no/
# MASKINPORTEN_SCOPE=brreg:data:enhetsregisteret:auto:roller
# MASKINPORTEN_RESOURCE=https://data.ppe.brreg.no/enhetsregisteret/autorisert-api
# BRREG_BASE_URL=https://data.ppe.brreg.no/enhetsregisteret/autorisert-api

# Port for BFF-serveren
PORT=3001
